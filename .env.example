# URL pública do site (usada em metadados, sitemap e dados estruturados)
NEXT_PUBLIC_SITE_URL=https://www.macclimatizacao.com.br

# WhatsApp principal da empresa (formato internacional, somente números)
NEXT_PUBLIC_WHATSAPP_NUMBER=5535999574681

# Google Analytics 4 (Measurement ID, ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Tag Manager (ID do container, ex: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Meta Pixel (Facebook/Instagram Ads)
NEXT_PUBLIC_META_PIXEL_ID=

# Código de verificação do Google Search Console (meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Link do perfil do Google Meu Negócio / Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_URL=https://share.google/3yOb5cXYNQsYpJWS6

# Link do Instagram
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/macclimatizacao_arcondicionado/

# Supabase — usado pelo painel administrativo (login, produtos e portfólio).
# Encontre esses valores em Project Settings > API no painel do Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
