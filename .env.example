# URL pública do site (usada em metadados, sitemap e dados estruturados)
NEXT_PUBLIC_SITE_URL=https://www.macclimatizacao.com.br

# WhatsApp principal da empresa (formato internacional, somente números)
NEXT_PUBLIC_WHATSAPP_NUMBER=5535999574681

# Google Analytics 4 (Measurement ID, ex: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Tag Manager (ID do container, ex: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Meta Pixel (Facebook/Instagram Ads)
NEXT_PUBLIC_META_PIXEL_ID=

# Código de verificação do Google Search Console (meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Link do perfil do Google Meu Negócio / Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_URL=https://share.google/3yOb5cXYNQsYpJWS6

# Link do Instagram
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/macclimatizacao_arcondicionado/

# Painel administrativo (/admin) — login simples de usuário e senha.
# ADMIN_SESSION_SECRET pode ser qualquer texto aleatório e longo (ex: gerado com
# `openssl rand -hex 32`), usado apenas para assinar o cookie de sessão.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Vercel Blob — armazena as fotos e os dados de produtos/portfólio do painel
# administrativo. É criado automaticamente ao conectar um "Blob Store" ao
# projeto na Vercel (Storage > Create Database > Blob); a variável abaixo é
# injetada sozinha lá. Para rodar localmente, copie o valor do dashboard da
# Vercel ou rode `vercel env pull`.
BLOB_READ_WRITE_TOKEN=
